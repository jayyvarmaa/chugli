# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Atlas
# Get your connection string from MongoDB Atlas Dashboard
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?appName=<appname>
MONGO_URI=your_mongodb_connection_string_here

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_in_production

# Frontend URL (for CORS and Socket.io)
# Development: http://localhost:5173
# Production: https://your-vercel-frontend-url.vercel.app
CLIENT_URL=http://localhost:5173

# Email Service (Resend)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Chugli
RESEND_PASSWORD_RESET_TEMPLATE_ID=your_template_id

# Image Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Security (Arcjet)
ARCJET_KEY=ajkey_your_arcjet_key
ARCJET_ENV=development